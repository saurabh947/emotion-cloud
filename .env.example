# Copy to .env and fill in values.  Never commit .env to git.

# ── gRPC ─────────────────────────────────────────────────────────────────────
GRPC_PORT=50051
GRPC_MAX_WORKERS=20

# ── TorchServe ────────────────────────────────────────────────────────────────
TORCHSERVE_HOST=localhost
TORCHSERVE_INFERENCE_PORT=8080
TORCHSERVE_MANAGEMENT_PORT=8081
MODEL_NAME=emotion-detector
MODEL_STORE_PATH=/opt/ml/model-store
TORCHSERVE_CONFIG_PATH=/opt/ml/config/config.properties

# ── Model ─────────────────────────────────────────────────────────────────────
DEVICE=cuda
USE_INT8=true

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TIMEOUT_SECONDS=300

# ── GCS ───────────────────────────────────────────────────────────────────────
# Bucket must exist and the VM's service account must have roles/storage.objectViewer.
WEIGHTS_GCS_URI=gs://emotion-cloud-models/weights/v1/
WEIGHTS_LOCAL_PATH=/opt/ml/model-store/weights
# Filename of the fine-tuned checkpoint inside WEIGHTS_LOCAL_PATH.
# Full resolved path = WEIGHTS_LOCAL_PATH/WEIGHTS_FILE_NAME.
WEIGHTS_FILE_NAME=phase2_last.pt

# ── Startup ───────────────────────────────────────────────────────────────────
TORCHSERVE_STARTUP_TIMEOUT=120
TORCHSERVE_STARTUP_POLL_INTERVAL=2.0
